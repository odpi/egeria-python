{
        "Environment": {
                "Console Width": 200,
                "Pyegeria Root": "/home/jovyan",
                "Pyegeria Config Directory": "",
                "Pyegeria Publishing Root": "http://host.docker.internal:8085/outbox",
                "Pyegeria User Report Specs Dir": "/home/jovyan/.pyegeria/report_specs",
                "Egeria Inbox": "loading-bay",
                "Egeria Outbox": "distribution-hub",
                "Dr.Egeria Inbox": "loading-bay/dr-egeria-inbox",
                "Dr.Egeria Outbox": "distribution-hub/dr-egeria-outbox",
                "Egeria Kafka Endpoint": "host.docker.internal:9192",
                "Egeria Jupyter": true,
                "Egeria Normalize Mermaid": true,
                "Egeria Platform URL": "https://host.docker.internal:9443",
                "Egeria View Server": "qs-view-server",
                "Egeria View Server URL": "https://host.docker.internal:9443",
                "Egeria Metadata Store": "qs-metadata-store",
                "Egeria Engine Host": "qs-engine-host",
                "Egeria Engine Host URL": "https://host.docker.internal:9443",
                "Egeria Integration Daemon": "qs-integration-daemon",
                "Egeria Integration Daemon URL": "https://host.docker.internal:9443",
                "Egeria Glossary Path": "/home/jovyan/loading-bay/glossary",
                "Egeria Mermaid Folder": "/home/jovyan/distribution-hub/mermaid-graphs"
        },
        "Logging": {
                "enable_logging": true,
                "log_directory": "/home/jovyan/logs",
                "console_logging_level": "WARNING",
                "console_filter_levels": [
                        "WARNING",
                        "ERROR"
                ],
                "console_logging_enabled": [
                        "tests",
                        "_exceptions_new",
                        "dr_egeria"
                ],
                "logging_console_format": " <green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level}</level> | <cyan>{name}</cyan>:<cyan>{line}</cyan> - <level>{message}</level> -{extra}",
                "file_logging_level": "INFO",
                "logging_file_format": " {time:YYYY-MM-DD HH:mm:ss} | {level} | {function}:{line} - {message}-{extra}"
        },
        "Debug": {
                "timeout_seconds": 30,
                "debug_mode": false,
                "enable_logger_catch": false
        },
        "User Profile": {
                "Egeria Home Glossary Name": "Egeria-Markdown",
                "Egeria Local Qualifier": "PDR",
                "Egeria Home Collection": "MyHome",
                "Egeria Usage Level": "Basic"
        }
}